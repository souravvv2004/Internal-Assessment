<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Internal Assessment System</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      background-color: #f8f9fa;
      padding-bottom: 50px;
    }
    h1 {
      text-align: center;
      font-size: 2.5rem; 
      color: #257cd3; 
      text-transform: uppercase; 
      letter-spacing: 2px; 
      font-weight: bold;
      margin-top: 50px; 
      margin-bottom: 40px;
    }

    /* 1. This forces every single card to have the exact same width and height */
    .custom-card {
      width: 20rem;
      height: 380px; 
      display: flex;
      flex-direction: column;
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    }

    /* 2. This locks the image area so different picture shapes don't resize the box */
    .img-container {
      height: 220px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 15px;
    }

    .img-container img {
      max-height: 100%;
      max-width: 100%;
      object-fit: contain;
    }

    .card-body {
      display: flex;
      flex-direction: column;
      justify-content: space-between; /* Pushes the button perfectly to the bottom */
      text-align: center;
      padding: 20px;
    }
  </style>
</head>
<body>

  <h1>Internal Assessment System</h1>
  
  <div class="container">
    
    <div class="row justify-content-center gap-5 mb-5">
      
      <div class="col-auto">
        <div class="custom-card">
          <div class="img-container">
            <img src="/student.png" alt="Student">
          </div>
          <div class="card-body">
            <h5 class="fw-bold m-0">Student</h5>
            <a href="/login" class="btn btn-primary w-100">Click here</a>
          </div>
        </div>
      </div>

      <div class="col-auto">
        <div class="custom-card">
          <div class="img-container">
            <img src="/teacher.png" alt="Teacher">
          </div>
          <div class="card-body">
            <h5 class="fw-bold m-0">Teacher</h5>
            <a href="/login" class="btn btn-primary w-100">Click here</a>
          </div>
        </div>
      </div>

    </div>

    <div class="row justify-content-center">
      
      <div class="col-auto">
        <div class="custom-card">
          <div class="img-container">
            <img src="/univ.png" alt="University">
          </div>
          <div class="card-body">
            <h5 class="fw-bold m-0">University</h5>
            <a href="/login" class="btn btn-primary w-100">Click here</a>
          </div>
        </div>
      </div>

    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>